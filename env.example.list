# Tableau-side auth (PAT used by the MCP server to talk to Tableau)
SERVER=https://my-tableau-server.com
SITE_NAME=
PAT_NAME=
PAT_VALUE=

# Transport — must be "http" when deployed to Railway / called from Snowflake.
# Auto-defaults to "http" whenever MCP_BEARER_TOKEN is set.
TRANSPORT=http

# Inbound auth for callers (e.g. Snowflake CREATE MCP SERVER).
# Generate a long random token (e.g. `openssl rand -hex 32`) and set the same
# value here AND in your Snowflake SECRET. Callers MUST send:
#   Authorization: Bearer <MCP_BEARER_TOKEN>
# Setting this also automatically disables the OAuth flow.
MCP_BEARER_TOKEN=

# Optional Tableau MCP knobs
DATASOURCE_CREDENTIALS=
DEFAULT_NOTIFICATION_LEVEL=info
INCLUDE_TOOLS=
EXCLUDE_TOOLS=
MAX_RESULT_LIMIT=
DISABLE_QUERY_DATASOURCE_VALIDATION_REQUESTS=
DISABLE_METADATA_API_REQUESTS=
